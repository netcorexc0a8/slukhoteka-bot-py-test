# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# VK Bot Token (получить в настройках группы VK)
VK_BOT_TOKEN=your_vk_bot_token_here
# ID группы VK (число)
VK_GROUP_ID=your_vk_group_id_here
# Yandex Disk Token (опционально)
YANDEX_DISK_TOKEN=your_yandex_disk_token_here
# Имя файла на Яндекс Диске
FILE_NAME=/Slukhoteka/Расписание.xlsx

# Database
POSTGRES_USER=slukhoteka
POSTGRES_PASSWORD=slukhoteka_pass
POSTGRES_DB=slukhoteka
DATABASE_URL=postgresql://slukhoteka:slukhoteka_pass@slukhoteka-db:5432/slukhoteka

# Backend
BACKEND_PORT=8000
BACKEND_URL=http://slukhoteka-backend:8000

# Sync settings (seconds)
SYNC_INTERVAL=120
CHECK_CHANGES_INTERVAL=60

# Admin User Phones (через запятую)
ADMIN_USER_PH=+79001234567,+79001234568

# Time slots (00:00 - 23:00, step 1 hour)
START_HOUR=0
END_HOUR=23
TIME_SLOT_DURATION=1

# Calendar colors
COLOR_FREE=🟩
COLOR_BUSY=🟨

# Timezone
TIMEZONE=Europe/Moscow